				$(document).ready(function () {
					function loadgal(){
						var p;
						var pprev;
						var pnext;
						var divcont = "";
						if(window.location.hash) {
							p = window.location.hash.substring(1);
							if((p < 1) || (p > 4) || (p == 'mc')){
								p = 1;
							}
						}
						else{
							p = 1;
						}
						
						$('.bgc5').attr("class", "p1");
						$('#pgn'+p).attr("class", "bgc5");

						if(p > 1){
							pprev = Number(p) - Number(1);
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+pprev);
							$('#pgnprev').attr("class", "prevnext prev pna");
						}
						else if(p == 'videos'){
							pprev = 4;
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+pprev);
							$('#pgnprev').attr("class", "prevnext prev pna");
						}
						else{
							$('#pgnprev').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+p);
							$('#pgnprev').attr("class", "prevnext prev off");
						}
						
						if(p < 4){
							pnext = Number(p) + Number(1);
							$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+pnext);
							$('#pgnnext').attr("class", "prevnext next pna");
						}
						else if(p == 4){
							if(false){
								pnext = "videos";
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+pnext);
								$('#pgnnext').attr("class", "prevnext next pna");
							}
							else{
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+p);
								$('#pgnnext').attr("class", "prevnext next off");
							}
						}
						else{
							if(p == 'videos'){
								$('#pgnnext').attr("href", "https://www.caricos.com/cars/v/volvo/2020_volvo_xc40_recharge/#"+p);
								$('#pgnnext').attr("class", "prevnext next off");
							}
						}
						
						if(p == 'videos'){
							var poffset = 4*100;
							$('#galmj').css("left", "-" + poffset + "%");
						}
						else{
							var poffset = (p-1)*100;
							$('#galmj').css("left", "-" + poffset + "%");
						}
						
						$("#galpage" + p + ", #galpage" + pprev + ", #galpage" + pnext).find("img").each(function(){
							var src = $(this).attr("data-src");
							$(this).attr("src", src);
							$(this).css("display", "block");
						
						});	

						$('#page-select').val(p);

						$('#page-select').on('change', function(){
							window.location.hash = $(this).val();
						});
					}

					// function hideimages(){
					// 	$("#galmj").find("img").each(function(){
					// 		var src = $(this).attr("src");
					// 		$(this).attr("data-src", src);
					// 		$(this).removeAttr("src");
					// 		$(this).css("display", "none");
						
					// 	});	
					// }

					// hideimages();
					loadgal();

					//window.onhashchange = loadgal;
					window.onhashchange = function () {
						if(window.location.hash) {
							p = window.location.hash.substring(1);
							if((p < 1) || (p > 4) || (p == 'mc')){
								p = 1;
							}
